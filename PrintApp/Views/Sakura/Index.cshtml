@model List<PrintApp.Models.SakuraAppTile>
@{
    ViewData["Title"] = "Sakura Home";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Barlow:wght@600;700;800&display=swap');

    /* ── Sigma Red design tokens — shared across all Sakura pages ─────────── */
    :root {
        --red:        #C8102E;
        --red-dark:   #9B0B22;
        --red-mid:    #E63950;
        --red-light:  #FFE5E9;
        --red-xlight: #FFF5F6;
        --white:      #FFFFFF;
        --gray-50:    #F9FAFB;
        --gray-100:   #F3F4F6;
        --gray-200:   #E5E7EB;
        --gray-400:   #9CA3AF;
        --gray-500:   #6B7280;
        --gray-600:   #4B5563;
        --gray-700:   #374151;
        --gray-900:   #111827;
        --success:    #059669;
        --danger:     #DC2626;
        --shadow-sm:  0 1px 3px rgba(200,16,46,0.08);
        --shadow-md:  0 4px 20px rgba(200,16,46,0.12);
        --shadow-lg:  0 8px 40px rgba(200,16,46,0.18);
        --font-body:  'Inter', sans-serif;
        --font-head:  'Barlow', sans-serif;
    }

    body {
        background: var(--gray-50) !important;
        background-image:
            radial-gradient(ellipse at 10% 30%, rgba(200,16,46,0.05) 0%, transparent 55%),
            radial-gradient(ellipse at 90% 70%, rgba(230,57,80,0.04) 0%, transparent 50%) !important;
        color: var(--gray-900) !important;
        font-family: var(--font-body) !important;
    }
    body::before { content: none !important; }

    .sk-page { max-width: 900px; margin: 0 auto; position: relative; z-index: 1; }

    .sk-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
    }
    .sk-header h1 { font-family: var(--font-head); font-size: 30px; font-weight: 800; letter-spacing: -0.3px; color: var(--red-dark); }
    .sk-header p {
        font-family: var(--font-body); font-size: 0.85rem;
        color: var(--gray-500); margin-top: 6px;
    }
    .sk-header .accent-bar {
        display: block; width: 40px; height: 4px; border-radius: 4px; margin-top: 12px;
        background: linear-gradient(90deg, var(--red-dark), var(--red-mid));
    }
    .sk-badge {
        background: var(--red-xlight); color: var(--red-dark); border: 1px solid var(--red-light);
        font-family: var(--font-body); font-size: 0.7rem; font-weight: 700; letter-spacing: 1px;
        text-transform: uppercase; padding: 6px 14px 6px 10px; border-radius: 20px;
        display: flex; align-items: center; gap: 6px; height: fit-content;
    }
    .sk-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0; }

    /* Section housing the app grid */
    .sk-board {
        background: var(--white); border: 1px solid rgba(200,16,46,0.07); border-radius: 18px;
        padding: 40px 30px 44px; margin-bottom: 20px; box-shadow: var(--shadow-md);
    }
    .sk-board-label {
        font-family: var(--font-body); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase;
        color: var(--gray-700); margin-bottom: 34px; display: flex; align-items: center; gap: 10px;
    }
    .sk-board-label::after { content: ''; flex: 1; height: 1px; background: var(--gray-200); }

    /* ── Group cards — folder-like grouping for related functions ─────────── */
    .sk-groups { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }
    .sk-group {
        border: 1px solid var(--gray-200); border-radius: 14px; background: var(--white);
        box-shadow: var(--shadow-sm); overflow: hidden;
    }
    .sk-group-header {
        display: flex; align-items: center; gap: 14px; padding: 16px 20px;
        background: var(--white); cursor: pointer; user-select: none;
        border-bottom: 1px solid transparent; transition: border-color 0.2s ease;
    }
    .sk-group.open .sk-group-header { border-bottom-color: var(--gray-200); }
    .sk-group-chevron {
        margin-left: auto; font-size: 13px; color: var(--gray-400); flex-shrink: 0;
        transition: transform 0.2s ease;
    }
    .sk-group.open .sk-group-chevron { transform: rotate(180deg); color: var(--red); }
    .sk-group-icon {
        width: 46px; height: 46px; border-radius: 12px; background: var(--red-xlight);
        border: 1px solid var(--red-light); display: flex; align-items: center; justify-content: center;
        font-size: 22px; flex-shrink: 0;
    }
    .sk-group-title { font-family: var(--font-head); font-size: 15px; font-weight: 700; letter-spacing: -0.2px; color: var(--gray-900); }
    .sk-group-subtitle { font-family: var(--font-body); font-size: 11.5px; color: var(--gray-500); margin-top: 2px; }

    .sk-group-items {
        display: flex; flex-direction: column;
        max-height: 0; overflow: hidden; transition: max-height 0.25s ease;
    }
    .sk-group.open .sk-group-items { max-height: 600px; }
    .sk-group-item {
        display: flex; align-items: center; gap: 14px; padding: 14px 20px;
        text-decoration: none; color: inherit; border-bottom: 1px dashed var(--gray-200);
        transition: background 0.15s ease;
    }
    .sk-group-item:last-child { border-bottom: none; }
    .sk-group-item:hover { background: var(--red-xlight); }
    .sk-group-item .icon { font-size: 20px; width: 30px; text-align: center; flex-shrink: 0; }
    .sk-group-item .txt { flex: 1; min-width: 0; }
    .sk-group-item .name { font-family: var(--font-body); font-size: 13px; font-weight: 600; color: var(--gray-900); }
    .sk-group-item .desc { font-family: var(--font-body); font-size: 11px; color: var(--gray-500); margin-top: 2px; }
    .sk-group-item .chevron { color: var(--gray-400); font-size: 14px; flex-shrink: 0; }

    /* ── App grid — "home screen" tiles ───────────────────────────────────── */
    .sk-app-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(112px, 1fr));
        gap: 30px 20px;
        justify-items: center;
    }

    .sk-app-tile {
        display: flex; flex-direction: column; align-items: center; gap: 10px;
        width: 112px; text-decoration: none; color: inherit; cursor: pointer;
        border: none; background: none; padding: 0; font: inherit;
    }
    .sk-app-icon {
        width: 72px; height: 72px; border-radius: 18px;
        background: var(--red-xlight); border: 1px solid var(--red-light);
        display: flex; align-items: center; justify-content: center;
        font-size: 30px; box-shadow: var(--shadow-sm);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }
    .sk-app-tile:hover .sk-app-icon {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: var(--red);
    }
    .sk-app-tile:active .sk-app-icon {
        transform: translateY(0);
        box-shadow: var(--shadow-sm);
    }
    .sk-app-tile .name {
        font-family: var(--font-body); font-size: 12px; font-weight: 600;
        letter-spacing: 0.1px; text-align: center; line-height: 1.3; color: var(--gray-900);
    }
    .sk-app-tile .desc {
        font-family: var(--font-body); font-size: 10.5px; color: var(--gray-500);
        text-align: center; line-height: 1.3;
    }

    /* Disabled / "coming soon" tile */
    .sk-app-tile.disabled { cursor: default; }
    .sk-app-tile.disabled .sk-app-icon {
        background: transparent; border-style: dashed; border-color: var(--gray-200); box-shadow: none; opacity: 0.6;
    }
    .sk-app-tile.disabled:hover .sk-app-icon { transform: none; box-shadow: none; border-color: var(--gray-200); }
    .sk-app-tile.disabled .name,
    .sk-app-tile.disabled .desc { opacity: 0.6; }

    .sk-footer {
        text-align: center; margin-top: 6px;
        font-family: var(--font-body); font-size: 0.7rem; letter-spacing: 0.5px;
        color: var(--gray-400);
    }

    /* ── Language switcher — fixed top-right, shared across all Sakura pages ── */
    .sk-lang-switch {
        position: fixed; top: 18px; right: 22px; z-index: 100;
        display: flex; gap: 8px;
        background: var(--white); border: 1px solid var(--gray-200); border-radius: 20px;
        padding: 5px 6px; box-shadow: var(--shadow-sm);
    }
    .sk-lang-flag {
        width: 26px; height: 26px; border-radius: 50%; overflow: hidden;
        border: 1.5px solid transparent; padding: 0; cursor: pointer; background: none;
        display: flex; align-items: center; justify-content: center;
        opacity: 0.5; transition: opacity 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }
    .sk-lang-flag img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .sk-lang-flag:hover { opacity: 0.85; transform: translateY(-1px); }
    .sk-lang-flag.active { opacity: 1; border-color: var(--red); box-shadow: 0 0 0 2px rgba(200,16,46,0.12); }

    @@media (max-width: 560px) {
        .sk-app-grid { grid-template-columns: repeat(auto-fill, minmax(92px, 1fr)); gap: 24px 14px; }
        .sk-app-tile { width: 92px; }
        .sk-app-icon { width: 62px; height: 62px; font-size: 26px; }
        .sk-lang-switch { top: 12px; right: 12px; padding: 4px 5px; gap: 6px; }
        .sk-lang-flag { width: 22px; height: 22px; }
    }
</style>

@await Html.PartialAsync("_LangSwitcher")

<div class="sk-page">

    <header class="sk-header">
        <div>
            <h1>SAKURA</h1>
            <p data-i18n="home.subtitle">Choose a function below</p>
            <span class="accent-bar"></span>
        </div>
        <div class="sk-badge">SAKURA</div>
    </header>

    <div class="sk-board">
        <div class="sk-board-label" data-i18n="home.section">Functions</div>

        <div class="sk-groups">
            @foreach (var group in (Model ?? new List<PrintApp.Models.SakuraAppTile>()).Where(t => t.Items != null && t.Items.Count > 0))
            {
                <div class="sk-group">
                    <div class="sk-group-header">
                        <div class="sk-group-icon">@group.Icon</div>
                        <div>
                            <div class="sk-group-title" data-i18n="tile.@(group.Key).title">@group.Title</div>
                            <div class="sk-group-subtitle" data-i18n="tile.@(group.Key).desc">@group.Subtitle</div>
                        </div>
                        <span class="sk-group-chevron">⌄</span>
                    </div>
                    <div class="sk-group-items">
                        @foreach (var item in group.Items!)
                        {
                            <a class="sk-group-item" href="@item.Href" target="@(item.OpenInNewTab ? "_blank" : null)" rel="@(item.OpenInNewTab ? "noopener noreferrer" : null)">
                                <span class="icon">@item.Icon</span>
                                <span class="txt">
                                    <div class="name" data-i18n="tile.@(item.Key).title">@item.Title</div>
                                    <div class="desc" data-i18n="tile.@(item.Key).desc">@item.Subtitle</div>
                                </span>
                                <span class="chevron">→</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="sk-app-grid">
            @foreach (var tile in (Model ?? new List<PrintApp.Models.SakuraAppTile>()).Where(t => t.Items == null || t.Items.Count == 0))
            {
                if (tile.Enabled && !string.IsNullOrEmpty(tile.Href))
                {
                    <a class="sk-app-tile" href="@tile.Href" target="@(tile.OpenInNewTab ? "_blank" : null)" rel="@(tile.OpenInNewTab ? "noopener noreferrer" : null)">
                        <div class="sk-app-icon">@tile.Icon</div>
                        <div class="name" data-i18n="tile.@(tile.Key).title">@tile.Title</div>
                        <div class="desc" data-i18n="tile.@(tile.Key).desc">@tile.Subtitle</div>
                    </a>
                }
                else
                {
                    <div class="sk-app-tile disabled" title="Coming soon" data-i18n-title="tile.@(tile.Key).title">
                        <div class="sk-app-icon">@tile.Icon</div>
                        <div class="name" data-i18n="tile.@(tile.Key).title">@tile.Title</div>
                        <div class="desc" data-i18n="tile.@(tile.Key).desc">@tile.Subtitle</div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="sk-footer" data-i18n="home.footer">Designed by SVN IT</div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/i18next@23.10.1/i18next.min.js"></script>
    <script src="~/js/sakura-i18n.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.sk-group-header').forEach(function (header) {
            header.addEventListener('click', function () {
                header.closest('.sk-group').classList.toggle('open');
            });
        });
    </script>
}
