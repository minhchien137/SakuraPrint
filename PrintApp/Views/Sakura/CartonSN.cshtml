@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/i18next@23.10.1/i18next.min.js"></script>
<script src="~/js/sakura-i18n.js" asp-append-version="true"></script>
<script>
(function () {
    const NODE_SERVICE = 'http://localhost:8021';
    const BASE = '@Url.Content("~")'.replace(/\/$/, '');
    const MAX_SN_PER_CARTON = 10;

    // t() reads the current language live via SakuraI18n — keeps dynamically
    // rendered text (status messages, USB scan results) in sync with EN/ZH.
    function t(key, fallback) {
        return window.SakuraI18n ? window.SakuraI18n.t(key) : fallback;
    }

    function escHtml(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function showStatus(el, msg, type) {
        el.textContent = msg;
        el.classList.remove('ok', 'err');
        el.classList.add('t-status', 'show', type);
    }
    function hideStatus(el) { el.classList.remove('show', 'ok', 'err'); }

    // ── Print Label: Work Order / Carton Number ───────────────────────────────
    const $workOrder     = document.getElementById('workOrder');
    const $cartonNumber  = document.getElementById('cartonNumber');
    const $cartonNumberStatus = document.getElementById('cartonNumberStatus');
    const $btnLookupWo   = document.getElementById('btnLookupWo');
    const $btnSaveWo     = document.getElementById('btnSaveWo');
    const $btnResetWo    = document.getElementById('btnResetWo');
    const $woStatus      = document.getElementById('woStatus');
    const $woResolved    = document.getElementById('woResolved');
    const $woColor       = document.getElementById('woColor');
    const $woQuantity    = document.getElementById('woQuantity');
    const $woCarton      = document.getElementById('woCarton');

    // Condition tạm cố định "New" — bỏ dropdown theo yêu cầu, sẽ có logic chọn riêng sau.
    const CARTON_FIXED_CONDITION = 'New';

    const LS_WO = 'sakura_cartonsn_workorder';
    const LS_CARTON = 'sakura_cartonsn_cartonnumber';

    // Trạng thái Work Order đã lookup — resolvedColor lấy tự động từ Odoo (không còn dropdown
    // Color để người dùng tự chọn), expectedQuantityThisCarton là số serial cần quét cho CARTON
    // HIỆN TẠI (đủ hộp = CartonPcsPerCarton, hoặc lẻ hộp = đúng phần dư còn lại của WO).
    let woResolvedOk = false;
    let resolvedColor = null;
    let woTotalQuantity = null;
    let woRemainingQuantity = null;
    let expectedQuantityThisCarton = null;
    let woStatusHideTimer = null;

    function loadWoFields() {
        const wo = localStorage.getItem(LS_WO);
        const carton = localStorage.getItem(LS_CARTON);
        if (wo) $workOrder.value = wo;
        if (carton) $cartonNumber.value = carton;
    }

    function resetWoState() {
        woResolvedOk = false;
        resolvedColor = null;
        woTotalQuantity = null;
        woRemainingQuantity = null;
        expectedQuantityThisCarton = null;
        $woResolved.style.display = 'none';

        // Chưa có Work Order hợp lệ (WO đã in hết, chưa lookup, hoặc đang gõ WO khác) -> không
        // cho nhập Carton Number/Serial Number, tránh quét nhầm vào 1 WO không rõ ràng. Chỉ mở
        // lại khi lookupWorkOrder() trả về thành công (xem cuối lookupWorkOrder()).
        $cartonNumber.value = '';
        $cartonNumber.disabled = true;
        $cartonNumber.classList.remove('invalid');
        hideStatus($cartonNumberStatus);
        $serialGrid.innerHTML = '';
        $scannedTotal.textContent = '0';
        $scannedCount.textContent = '0';
        serialList = [];

        // Print Pallet cần biết màu (SKU/PV ID + EAN) từ WO đã resolve -> khóa lại cùng lúc.
        setPalletUnlocked(false);
    }

    async function lookupWorkOrder() {
        const wo = $workOrder.value.trim();
        resetWoState();

        // WO đã đổi so với lần Save gần nhất -> đèn "đã save" không còn đúng nữa.
        if (wo !== localStorage.getItem(LS_WO)) {
            $btnSaveWo.classList.remove('is-saved');
        }

        clearTimeout(woStatusHideTimer);

        if (!wo) {
            showStatus($woStatus, `✗ ${t('cartonsn.woEnterFirst', 'Enter a Work Order first.')}`, 'err');
            return;
        }

        showStatus($woStatus, `⏳ ${t('cartonsn.woLookingUp', 'Looking up…')}`, 'ok');
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/workorder-lookup?workOrder=${encodeURIComponent(wo)}`);
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.lookupFailed', 'Lookup failed.')));

            resolvedColor = body.data.color;
            woTotalQuantity = body.data.totalQuantity;
            woRemainingQuantity = body.data.remainingQuantity;
            expectedQuantityThisCarton = body.data.expectedQuantity;

            $woColor.textContent = resolvedColor;
            $woQuantity.textContent = `${woRemainingQuantity}/${woTotalQuantity}`;
            $woCarton.textContent = `${body.data.remainingCarton}/${body.data.totalCarton}`;
            $woResolved.style.display = 'grid';
            woResolvedOk = true;

            // WO hợp lệ + còn hàng -> mở lại Carton Number/Serial Number cho quét (resetWoState()
            // ở đầu hàm đã khóa lại từ trước). Tự áp dụng số lượng serial cần quét cho carton
            // hiện tại (đủ hộp hoặc lẻ hộp).
            buildSerialGrid(expectedQuantityThisCarton);
            updateCartonNumberLock();
            setPalletUnlocked(true);

            const lookupMsg = t('cartonsn.woLookupSuccess', '{color} — this carton needs {qty} serial(s).')
                .replace('{color}', resolvedColor).replace('{qty}', expectedQuantityThisCarton);
            showStatus($woStatus, `✓ ${lookupMsg}`, 'ok');
            woStatusHideTimer = setTimeout(() => { $woStatus.className = 't-status'; }, 5000);

            // Luồng tuần tự bắt buộc: Work Order -> Pallet ID -> Carton Number. Pallet ID CHƯA
            // từng Save thì trỏ xuống đó trước (bắt nhập/xác nhận Pallet ID); đã Save rồi thì bỏ
            // qua, nhảy thẳng xuống Carton Number như cũ.
            if (!localStorage.getItem(LS_PALLET.id)) {
                $palletId.focus();
            } else {
                $cartonNumber.focus();
            }
        } catch (e) {
            // Lookup fail (vd WO đã in đủ số lượng) -> Carton Number/Serial Number vẫn đang khóa
            // (resetWoState() ở đầu hàm) — chỉ hiện thông báo + gợi ý đổi WO, KHÔNG tự làm gì
            // thêm, để người vận hành tự nhận ra và đổi Work Order khác rồi Lookup lại.
            showStatus($woStatus, `✗ ${e.message} ${t('cartonsn.pleaseChangeWo', 'Please change the Work Order and look up again.')}`, 'err');
        }
    }

    $btnLookupWo.addEventListener('click', lookupWorkOrder);
    $workOrder.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); lookupWorkOrder(); }
    });
    $workOrder.addEventListener('input', () => {
        if ($workOrder.value.trim() !== localStorage.getItem(LS_WO)) {
            $btnSaveWo.classList.remove('is-saved');
        }
        if (woResolvedOk) resetWoState();
    });

    // ── Save / Reset Work Order — Save ghi WO+Carton Number hiện tại vào localStorage để
    // lần sau mở trang tự điền; Reset xóa ô nhập và mọi state đã resolve. ─────────────────
    $btnSaveWo.addEventListener('click', () => {
        const wo = $workOrder.value.trim();
        if (!wo) {
            showStatus($woStatus, `✗ ${t('cartonsn.woEnterFirst', 'Enter a Work Order first.')}`, 'err');
            return;
        }
        localStorage.setItem(LS_WO, wo);
        localStorage.setItem(LS_CARTON, $cartonNumber.value.trim());
        showStatus($woStatus, `✓ ${t('cartonsn.savedMsg', '✓ Saved.')}`, 'ok');
        clearTimeout(woStatusHideTimer);
        woStatusHideTimer = setTimeout(() => { $woStatus.className = 't-status'; }, 5000);
        $btnSaveWo.classList.add('is-saved');
    });

    $btnResetWo.addEventListener('click', () => {
        clearTimeout(woStatusHideTimer);
        $workOrder.value = '';
        resetWoState(); // xóa Carton Number + khóa lại, xóa toàn bộ ô Serial Number
        localStorage.removeItem(LS_WO);
        localStorage.removeItem(LS_CARTON);
        $woStatus.className = 't-status';
        $btnSaveWo.classList.remove('is-saved');
        $workOrder.focus();
    });

    // ── Print Pallet — gom carton đã in vào 1 Pallet ID, đếm realtime, sinh Pallet Number lúc
    // in tem. Khóa cả vùng cho tới khi WO đã lookup thành công (cần resolvedColor để tra
    // SKU/PV ID + EAN) — xem setPalletUnlocked() gọi từ resetWoState()/lookupWorkOrder(). ──────
    const $palletFieldset = document.getElementById('palletFieldset');
    const $palletLockedHint = document.getElementById('palletLockedHint');
    const $palletId = document.getElementById('palletId');
    const $poNumber = document.getElementById('poNumber');
    const $palletTemplateSelect = document.getElementById('palletTemplateSelect');
    const $btnManagePalletTemplate = document.getElementById('btnManagePalletTemplate');
    const $palletManualFieldsWrap = document.getElementById('palletManualFieldsWrap');
    const $inboundReference = document.getElementById('inboundReference');
    const $warehouseReference = document.getElementById('warehouseReference');
    const $deliveryAddress = document.getElementById('deliveryAddress');
    const $btnSavePalletInfo = document.getElementById('btnSavePalletInfo');
    const $btnResetPalletInfo = document.getElementById('btnResetPalletInfo');
    const $palletBoxCount = document.getElementById('palletBoxCount');
    const $btnManagePallet = document.getElementById('btnManagePallet');
    const $btnPrintPalletLabel = document.getElementById('btnPrintPalletLabel');
    const $palletAutoPrintTarget = document.getElementById('palletAutoPrintTarget');
    const $palletStatus = document.getElementById('palletStatus');

    const LS_PALLET = {
        id: 'sakura_cartonsn_pallet_id',
        templateSelection: 'sakura_cartonsn_pallet_template_selection',
        manualPoNumber: 'sakura_cartonsn_pallet_manual_po',
        manualInbound: 'sakura_cartonsn_pallet_manual_inbound',
        manualWarehouse: 'sakura_cartonsn_pallet_manual_warehouse',
        manualAddress: 'sakura_cartonsn_pallet_manual_address',
        autoPrintTarget: 'sakura_cartonsn_pallet_autoprint_target',
        savedFlag: 'sakura_cartonsn_pallet_saved_flag'
    };

    function setPalletUnlocked(unlocked) {
        $palletFieldset.disabled = !unlocked;
        $palletLockedHint.style.display = unlocked ? 'none' : '';
        updatePrintPalletButtonState();
        if (unlocked) refreshPalletBadge();
    }

    function loadPalletFields() {
        const v = k => localStorage.getItem(k);
        if (v(LS_PALLET.id)) $palletId.value = v(LS_PALLET.id);
        if (v(LS_PALLET.autoPrintTarget)) $palletAutoPrintTarget.value = v(LS_PALLET.autoPrintTarget);
        if (v(LS_PALLET.savedFlag) === '1') $btnSavePalletInfo.classList.add('is-saved');
        updatePrintPalletButtonState();
    }

    // "Auto Print At" (tùy chọn) — set 1 số VD 64 thì cứ mỗi Pallet ID quét đủ tới đúng số đó là
    // tự động in tem Pallet ngay (không cần bấm Print Pallet Label), và nút Print Pallet Label bị
    // khóa (tối) khi Boxes in Pallet CHƯA đạt số này. Không set gì -> giữ hành vi cũ (in lúc nào
    // cũng được, không tự in). Setting này áp dụng chung cho các Pallet ID kế tiếp trong phiên
    // làm việc (không reset theo từng pallet) — lưu localStorage riêng, không nằm trong Save/Reset
    // Pallet Info (những field đó là dữ liệu CỦA 1 pallet, còn số này là CẤU HÌNH của cả quy trình).
    function getPalletTargetBoxCount() {
        const n = parseInt($palletAutoPrintTarget.value);
        return (Number.isFinite(n) && n > 0) ? n : null;
    }
    function updatePrintPalletButtonState() {
        const target = getPalletTargetBoxCount();
        const boxCount = parseInt($palletBoxCount.textContent) || 0;
        $btnPrintPalletLabel.disabled = !!target && boxCount < target;
    }
    function setPalletBoxCount(n) {
        $palletBoxCount.textContent = String(n);
        updatePrintPalletButtonState();
    }
    $palletAutoPrintTarget.addEventListener('input', () => {
        const raw = $palletAutoPrintTarget.value.trim();
        if (raw) localStorage.setItem(LS_PALLET.autoPrintTarget, raw);
        else localStorage.removeItem(LS_PALLET.autoPrintTarget);
        updatePrintPalletButtonState();
    });

    // Save/Reset Pallet Info — cùng pattern với Save/Reset Work Order: bấm Save thì nút chuyển
    // xanh (is-saved) và giữ nguyên tới khi có field nào đổi hoặc bấm Reset.
    $btnSavePalletInfo.addEventListener('click', () => {
        localStorage.setItem(LS_PALLET.id, $palletId.value.trim());
        localStorage.setItem(LS_PALLET.templateSelection, $palletTemplateSelect.value);
        if ($palletTemplateSelect.value === '__manual__') {
            localStorage.setItem(LS_PALLET.manualPoNumber, $poNumber.value.trim());
            localStorage.setItem(LS_PALLET.manualInbound, $inboundReference.value.trim());
            localStorage.setItem(LS_PALLET.manualWarehouse, $warehouseReference.value.trim());
            localStorage.setItem(LS_PALLET.manualAddress, $deliveryAddress.value.trim());
        }
        localStorage.setItem(LS_PALLET.savedFlag, '1');
        showStatus($palletStatus, `✓ ${t('cartonsn.savedMsg', '✓ Saved.')}`, 'ok');
        setTimeout(() => hideStatus($palletStatus), 3000);
        $btnSavePalletInfo.classList.add('is-saved');
    });

    $btnResetPalletInfo.addEventListener('click', () => {
        $palletId.value = '';
        $palletTemplateSelect.value = '';
        applyTemplateSelection('');
        $poNumber.value = '';
        $inboundReference.value = '';
        $warehouseReference.value = '';
        $deliveryAddress.value = '';
        $palletAutoPrintTarget.value = '';
        localStorage.removeItem(LS_PALLET.id);
        localStorage.removeItem(LS_PALLET.templateSelection);
        localStorage.removeItem(LS_PALLET.manualPoNumber);
        localStorage.removeItem(LS_PALLET.manualInbound);
        localStorage.removeItem(LS_PALLET.manualWarehouse);
        localStorage.removeItem(LS_PALLET.manualAddress);
        localStorage.removeItem(LS_PALLET.autoPrintTarget);
        localStorage.removeItem(LS_PALLET.savedFlag);
        setPalletBoxCount(0);
        hideStatus($palletStatus);
        $btnSavePalletInfo.classList.remove('is-saved');
        updateCartonNumberLock(); // Pallet ID vừa xoá -> khoá lại Carton Number/Serial Number
        $palletId.focus();
    });

    // Field nào trong Pallet Info đổi so với lần Save gần nhất -> đèn "đã save" không còn đúng —
    // xoá luôn cờ đã lưu (savedFlag) để F5 lại trang không hiện xanh nhầm nữa.
    function clearPalletSavedFlag() {
        $btnSavePalletInfo.classList.remove('is-saved');
        localStorage.removeItem(LS_PALLET.savedFlag);
    }
    [$palletId, $poNumber, $inboundReference, $warehouseReference, $deliveryAddress].forEach(el => {
        el.addEventListener('input', clearPalletSavedFlag);
    });
    $palletTemplateSelect.addEventListener('change', clearPalletSavedFlag);

    // ── Pallet Info Template — preset PO Number/Inbound Reference/Warehouse Reference/Delivery
    // Address. Chọn 1 template có sẵn -> 4 field này ẨN hẳn đi (dữ liệu đã xem được trong modal
    // Manage Templates, không cần lặp lại trên form); chọn "Manual" mới HIỆN 4 field để gõ tay.
    // Pallet ID KHÔNG nằm trong template — luôn nhập tay riêng (đổi theo từng pallet). ──────────
    let palletTemplates = [];

    function applyTemplateSelection(value) {
        if (value === '__manual__') {
            $palletManualFieldsWrap.style.display = '';
            $poNumber.value = localStorage.getItem(LS_PALLET.manualPoNumber) || '';
            $inboundReference.value = localStorage.getItem(LS_PALLET.manualInbound) || '';
            $warehouseReference.value = localStorage.getItem(LS_PALLET.manualWarehouse) || '';
            $deliveryAddress.value = localStorage.getItem(LS_PALLET.manualAddress) || '';
        } else {
            // Đã chọn 1 template có sẵn (hoặc chưa chọn gì) -> ẩn 4 field này đi, khỏi lặp lại
            // dữ liệu người dùng đã thấy trong modal Manage Templates. Vẫn gán .value bình thường
            // (dù input đang ẩn) để doPrintPalletLabel()/doTestPrintPalletLabel() đọc đúng giá trị.
            $palletManualFieldsWrap.style.display = 'none';
            const tpl = value ? palletTemplates.find(x => String(x.id) === String(value)) : null;
            $poNumber.value = tpl ? (tpl.poNumber || '') : '';
            $inboundReference.value = tpl ? (tpl.inboundReference || '') : '';
            $warehouseReference.value = tpl ? (tpl.warehouseReference || '') : '';
            $deliveryAddress.value = tpl ? (tpl.deliveryAddress || '') : '';
        }
    }

    function renderTemplateDropdown() {
        const current = $palletTemplateSelect.value;
        const optionsHtml = palletTemplates.map(tpl => `<option value="${tpl.id}">${escHtml(tpl.templateName)}</option>`).join('');
        $palletTemplateSelect.querySelectorAll('option[value]:not([value=""]):not([value="__manual__"])').forEach(o => o.remove());
        $palletTemplateSelect.insertAdjacentHTML('beforeend', optionsHtml);
        if (Array.from($palletTemplateSelect.options).some(o => o.value === current)) $palletTemplateSelect.value = current;
    }

    async function fetchPalletTemplates() {
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet-template`);
            const body = await res.json();
            if (res.ok && body.ok) palletTemplates = body.data || [];
        } catch (e) { /* dropdown just keeps Select/Manual options */ }
        renderTemplateDropdown();
        renderTemplateManageTable();
    }

    async function initPalletTemplates() {
        await fetchPalletTemplates();
        const saved = localStorage.getItem(LS_PALLET.templateSelection) || '';
        const optionExists = Array.from($palletTemplateSelect.options).some(o => o.value === saved);
        $palletTemplateSelect.value = optionExists ? saved : '';
        applyTemplateSelection($palletTemplateSelect.value);
    }

    // Chỉ áp dụng lên form ngay (để build ZPL/in được luôn) — LƯU lựa chọn này lại (để lần sau
    // mở trang tự khôi phục) chỉ xảy ra khi bấm nút 💾 Save Info, giống Pallet ID.
    $palletTemplateSelect.addEventListener('change', () => {
        applyTemplateSelection($palletTemplateSelect.value);
    });

    // Modal "Manage Info Templates" — CRUD template dùng cho dropdown ở trên.
    const $palletTemplateManageOverlay = document.getElementById('palletTemplateManageOverlay');
    const $btnClosePalletTemplateManage = document.getElementById('btnClosePalletTemplateManage');
    const $templateNameInput = document.getElementById('templateNameInput');
    const $templatePoNumberInput = document.getElementById('templatePoNumberInput');
    const $templateInboundInput = document.getElementById('templateInboundInput');
    const $templateWarehouseInput = document.getElementById('templateWarehouseInput');
    const $templateAddressInput = document.getElementById('templateAddressInput');
    const $btnSaveTemplate = document.getElementById('btnSaveTemplate');
    const $btnCancelEditTemplate = document.getElementById('btnCancelEditTemplate');
    const $templateManageStatus = document.getElementById('templateManageStatus');
    const $templateTableBody = document.getElementById('templateTableBody');
    const $templateEmptyHint = document.getElementById('templateEmptyHint');

    let editingTemplateId = null;

    function resetTemplateForm() {
        editingTemplateId = null;
        $templateNameInput.value = '';
        $templatePoNumberInput.value = '';
        $templateInboundInput.value = '';
        $templateWarehouseInput.value = '';
        $templateAddressInput.value = '';
        $btnSaveTemplate.textContent = t('cartonsn.templateSaveBtn', '💾 Save Template');
        $btnCancelEditTemplate.style.display = 'none';
    }

    function openPalletTemplateManage() {
        $palletTemplateManageOverlay.style.display = 'flex';
        hideStatus($templateManageStatus);
        resetTemplateForm();
        renderTemplateManageTable();
    }
    function closePalletTemplateManage() { $palletTemplateManageOverlay.style.display = 'none'; }

    $btnManagePalletTemplate.addEventListener('click', openPalletTemplateManage);
    $btnClosePalletTemplateManage.addEventListener('click', closePalletTemplateManage);
    $palletTemplateManageOverlay.addEventListener('click', (e) => { if (e.target === $palletTemplateManageOverlay) closePalletTemplateManage(); });
    $btnCancelEditTemplate.addEventListener('click', resetTemplateForm);

    function renderTemplateManageTable() {
        if (!$templateTableBody) return;
        $templateTableBody.innerHTML = palletTemplates.map(tpl => `
            <tr>
                <td>${escHtml(tpl.templateName)}</td>
                <td>${escHtml(tpl.poNumber || '')}</td>
                <td>${escHtml(tpl.inboundReference || '')}</td>
                <td>${escHtml(tpl.warehouseReference || '')}</td>
                <td>${escHtml(tpl.deliveryAddress || '')}</td>
                <td><button type="button" class="pm-edit-btn" data-id="${tpl.id}">${t('cartonsn.templateColEdit', 'Edit')}</button></td>
                <td><button type="button" class="pm-del-btn" data-id="${tpl.id}">${t('cartonsn.templateColDelete', 'Delete')}</button></td>
            </tr>`).join('');
        $templateEmptyHint.style.display = palletTemplates.length === 0 ? '' : 'none';
        $templateTableBody.querySelectorAll('.pm-edit-btn').forEach(btn => {
            btn.addEventListener('click', () => startEditTemplate(btn.getAttribute('data-id')));
        });
        $templateTableBody.querySelectorAll('.pm-del-btn').forEach(btn => {
            btn.addEventListener('click', () => deleteTemplate(btn.getAttribute('data-id')));
        });
    }

    function startEditTemplate(id) {
        const tpl = palletTemplates.find(x => String(x.id) === String(id));
        if (!tpl) return;
        editingTemplateId = tpl.id;
        $templateNameInput.value = tpl.templateName;
        $templatePoNumberInput.value = tpl.poNumber || '';
        $templateInboundInput.value = tpl.inboundReference || '';
        $templateWarehouseInput.value = tpl.warehouseReference || '';
        $templateAddressInput.value = tpl.deliveryAddress || '';
        $btnSaveTemplate.textContent = t('cartonsn.templateUpdateBtn', '💾 Update Template');
        $btnCancelEditTemplate.style.display = '';
    }

    $btnSaveTemplate.addEventListener('click', async () => {
        const name = $templateNameInput.value.trim();
        if (!name) {
            showStatus($templateManageStatus, `✗ ${t('cartonsn.templateNameRequired', 'Please enter a Template Name.')}`, 'err');
            return;
        }
        const payload = {
            templateName: name,
            poNumber: $templatePoNumberInput.value.trim(),
            inboundReference: $templateInboundInput.value.trim(),
            warehouseReference: $templateWarehouseInput.value.trim(),
            deliveryAddress: $templateAddressInput.value.trim()
        };
        $btnSaveTemplate.disabled = true;
        try {
            const url = editingTemplateId
                ? `${BASE}/api/sakura/cartonsn/pallet-template/${editingTemplateId}`
                : `${BASE}/api/sakura/cartonsn/pallet-template`;
            const res = await fetch(url, {
                method: editingTemplateId ? 'PUT' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.templateSaveFailed', 'Could not save template.')));

            const wasEditingSelectedTemplate = editingTemplateId !== null && String($palletTemplateSelect.value) === String(editingTemplateId);
            await fetchPalletTemplates();
            if (wasEditingSelectedTemplate) {
                $palletTemplateSelect.value = String(editingTemplateId);
                applyTemplateSelection($palletTemplateSelect.value);
            }
            resetTemplateForm();
            showStatus($templateManageStatus, `✓ ${t('cartonsn.templateSavedMsg', '✓ Template saved.')}`, 'ok');
        } catch (e) {
            showStatus($templateManageStatus, `✗ ${e.message}`, 'err');
        } finally {
            $btnSaveTemplate.disabled = false;
        }
    });

    async function deleteTemplate(id) {
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet-template/${id}`, { method: 'DELETE' });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.templateDeleteFailed', 'Could not delete template.')));

            const wasSelected = String($palletTemplateSelect.value) === String(id);
            await fetchPalletTemplates();
            if (wasSelected) {
                $palletTemplateSelect.value = '';
                localStorage.setItem(LS_PALLET.templateSelection, '');
                applyTemplateSelection('');
            }
            if (editingTemplateId !== null && String(editingTemplateId) === String(id)) resetTemplateForm();
            showStatus($templateManageStatus, `✓ ${t('cartonsn.templateDeletedMsg', '✓ Template deleted.')}`, 'ok');
        } catch (e) {
            showStatus($templateManageStatus, `✗ ${e.message}`, 'err');
        }
    }

    // Chặn in khi chưa chọn Template (hoặc ở chế độ Manual mà 3 field còn trống) / chưa nhập PO
    // Number — gọi từ cả doPrintPalletLabel() lẫn doTestPrintPalletLabel().
    function validatePalletInfoFields() {
        const templateValue = $palletTemplateSelect.value;
        if (!templateValue) return t('cartonsn.templateSelectRequired', 'Please select (or create) an Info Template before printing.');
        if (templateValue === '__manual__') {
            if (!$poNumber.value.trim() || !$inboundReference.value.trim() || !$warehouseReference.value.trim() || !$deliveryAddress.value.trim()) {
                return t('cartonsn.templateFieldsRequiredManual', 'Please fill in PO Number, Inbound Reference, Warehouse Reference and Delivery Address.');
            }
        }
        return null;
    }

    // Badge "📦 Boxes in Pallet: N" — chỉ hiển thị, không phải nút bấm. Refresh khi Pallet ID
    // đổi (debounce), sau khi thêm/xoá thùng trong modal Quản lý, và lúc mở khoá vùng này.
    async function refreshPalletBadge() {
        const palletId = $palletId.value.trim();
        if (!palletId) { setPalletBoxCount(0); return; }
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet/boxes?palletId=${encodeURIComponent(palletId)}`);
            const body = await res.json();
            if (res.ok && body.ok) setPalletBoxCount(body.data.boxCount);
        } catch (e) { /* chỉ là badge hiển thị — im lặng bỏ qua lỗi mạng, không chặn thao tác khác */ }
    }

    let palletIdDebounce;
    $palletId.addEventListener('input', () => {
        clearTimeout(palletIdDebounce);
        palletIdDebounce = setTimeout(refreshPalletBadge, 300);
        updateCartonNumberLock();
    });

    // Carton Number chỉ mở khi WO đã resolve VÀ Pallet ID đã có giá trị — luồng tuần tự bắt
    // buộc Work Order -> Pallet ID -> Carton Number, không cho nhảy cóc xuống quét Carton
    // Number/Serial Number khi chưa xác định Pallet ID (1 Pallet ID = 1 Work Order riêng).
    function cartonNumberPrereqOk() {
        return woResolvedOk && $palletId.value.trim() !== '';
    }
    function updateCartonNumberLock() {
        const unlocked = cartonNumberPrereqOk();
        if (!unlocked) {
            $cartonNumber.value = '';
            $cartonNumber.classList.remove('invalid');
            hideStatus($cartonNumberStatus);
            lockSerialGrid();
        }
        $cartonNumber.disabled = !unlocked;
    }

    // ── Modal "Quản lý Pallet" — xem danh sách Carton Number đã gán vào Pallet ID hiện tại, xoá
    // từng dòng để gỡ carton khỏi pallet (trừ lại số đếm). Không còn ô thêm tay ở đây — carton
    // được gán vào pallet ở luồng in chính (Print Label Carton), không qua modal này nữa. ──────
    const $palletManageOverlay = document.getElementById('palletManageOverlay');
    const $btnClosePalletManage = document.getElementById('btnClosePalletManage');
    const $palletManageNoId = document.getElementById('palletManageNoId');
    const $palletManageContent = document.getElementById('palletManageContent');
    const $manageStatus = document.getElementById('manageStatus');
    const $manageTableBody = document.getElementById('manageTableBody');
    const $manageEmptyHint = document.getElementById('manageEmptyHint');

    function openPalletManage() {
        $palletManageOverlay.style.display = 'flex';
        hideStatus($manageStatus);
        if (!$palletId.value.trim()) {
            $palletManageNoId.style.display = '';
            $palletManageContent.style.display = 'none';
            return;
        }
        $palletManageNoId.style.display = 'none';
        $palletManageContent.style.display = '';
        loadManageBoxes();
    }
    function closePalletManage() { $palletManageOverlay.style.display = 'none'; }

    $btnManagePallet.addEventListener('click', openPalletManage);
    $btnClosePalletManage.addEventListener('click', closePalletManage);
    $palletManageOverlay.addEventListener('click', (e) => { if (e.target === $palletManageOverlay) closePalletManage(); });

    function renderManageTable(boxes) {
        $manageTableBody.innerHTML = boxes.map(b => `
            <tr>
                <td>${b.id}</td>
                <td>${escHtml(b.cartonNumber)}</td>
                <td>${escHtml(b.palletId || '')}</td>
                <td><button type="button" class="pm-del-btn" data-carton="${escHtml(b.cartonNumber)}">${t('cartonsn.manageColDelete', 'Delete')}</button></td>
            </tr>`).join('');
        $manageEmptyHint.style.display = boxes.length === 0 ? '' : 'none';
        $manageTableBody.querySelectorAll('.pm-del-btn').forEach(btn => {
            btn.addEventListener('click', () => unscanCarton(btn.getAttribute('data-carton')));
        });
    }

    async function loadManageBoxes() {
        const palletId = $palletId.value.trim();
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet/boxes?palletId=${encodeURIComponent(palletId)}`);
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.managePalletLoadFailed', 'Could not load pallet boxes.')));
            renderManageTable(body.data.boxes);
            setPalletBoxCount(body.data.boxCount);
        } catch (e) {
            showStatus($manageStatus, `✗ ${e.message}`, 'err');
        }
    }

    async function unscanCarton(cartonNumber) {
        const palletId = $palletId.value.trim();
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet/unscan-box`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ palletId, cartonNumber })
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.manageUnscanFailed', 'Could not remove this box from the pallet.')));
            renderManageTable(body.data.boxes);
            setPalletBoxCount(body.data.boxCount);
        } catch (e) {
            showStatus($manageStatus, `✗ ${e.message}`, 'err');
        }
    }

    // ── In tem Pallet — server tự tính lại tổng thùng/unit từ DB (không tin số client), sinh
    // (hoặc dùng lại nếu Pallet ID này đã từng in) Pallet Number, rồi gửi ZPL qua CHUNG khối
    // Printer Configuration/Local Bridge với luồng in Carton Label ở trên. Bấm nút Print KHÔNG in
    // ngay — mở modal tóm tắt toàn bộ trường sẽ có trên tem để soát lại, chỉ in thật khi bấm
    // "Confirm & Print" trong modal đó (xem openPalletPrintConfirm()/executePalletPrint()). ──────
    const $palletPrintConfirmOverlay = document.getElementById('palletPrintConfirmOverlay');
    const $palletPrintConfirmBody = document.getElementById('palletPrintConfirmBody');
    const $btnClosePalletPrintConfirm = document.getElementById('btnClosePalletPrintConfirm');
    const $btnCancelPrintPalletConfirm = document.getElementById('btnCancelPrintPalletConfirm');
    const $btnConfirmPrintPalletLabel = document.getElementById('btnConfirmPrintPalletLabel');

    function closePalletPrintConfirm() { $palletPrintConfirmOverlay.style.display = 'none'; }

    function openPalletPrintConfirm(palletId) {
        const templateValue = $palletTemplateSelect.value;
        const templateLabel = templateValue === '__manual__'
            ? t('cartonsn.palletTemplateManualOption', '✏️ Manual (type manually)')
            : ($palletTemplateSelect.selectedOptions[0] ? $palletTemplateSelect.selectedOptions[0].textContent : '—');

        const rows = [
            [t('cartonsn.palletId', 'Pallet ID'), palletId],
            [t('cartonsn.workOrder', 'Work Order'), $workOrder.value.trim()],
            [t('cartonsn.color', 'Color'), resolvedColor || '—'],
            [t('cartonsn.palletTemplate', 'Pallet Info Template'), templateLabel],
            [t('cartonsn.poNumber', 'PO Number'), $poNumber.value.trim() || '—'],
            [t('cartonsn.inboundReference', 'Inbound Reference'), $inboundReference.value.trim() || '—'],
            [t('cartonsn.warehouseReference', 'Warehouse Reference'), $warehouseReference.value.trim() || '—'],
            [t('cartonsn.deliveryAddress', 'Delivery Address'), $deliveryAddress.value.trim() || '—'],
            [t('cartonsn.boxesInPalletLabel', '📦 Boxes in Pallet:').replace(/[:：]\s*$/, ''), $palletBoxCount.textContent]
        ];
        $palletPrintConfirmBody.innerHTML = rows.map(([k, v]) => `<tr><td>${escHtml(k)}</td><td>${escHtml(v)}</td></tr>`).join('');
        $palletPrintConfirmOverlay.dataset.palletId = palletId;
        $palletPrintConfirmOverlay.style.display = 'flex';
    }

    $btnClosePalletPrintConfirm.addEventListener('click', closePalletPrintConfirm);
    $btnCancelPrintPalletConfirm.addEventListener('click', closePalletPrintConfirm);
    $palletPrintConfirmOverlay.addEventListener('click', (e) => { if (e.target === $palletPrintConfirmOverlay) closePalletPrintConfirm(); });

    async function doPrintPalletLabel() {
        const palletId = $palletId.value.trim();
        if (!palletId) {
            showStatus($palletStatus, `✗ ${t('cartonsn.managePalletIdRequired', 'Enter a Pallet ID first.')}`, 'err');
            return;
        }
        if (!woResolvedOk || !resolvedColor) {
            showStatus($palletStatus, `✗ ${t('cartonsn.woLookupRequired', 'Look up a Work Order first.')}`, 'err');
            return;
        }
        const palletInfoError = validatePalletInfoFields();
        if (palletInfoError) {
            showStatus($palletStatus, `✗ ${palletInfoError}`, 'err');
            return;
        }
        if (!bridgeOnline || !isPrinterConfigured()) {
            showStatus($palletStatus, `✗ ${printerNotReadyMessage()}`, 'err');
            return;
        }

        openPalletPrintConfirm(palletId);
    }

    async function executePalletPrint(palletId, notice) {
        $btnConfirmPrintPalletLabel.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet/print`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    palletId,
                    poNumber: $poNumber.value.trim(),
                    inboundReference: $inboundReference.value.trim(),
                    warehouseReference: $warehouseReference.value.trim(),
                    deliveryAddress: $deliveryAddress.value.trim()
                })
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.printPalletFailed', 'Print Pallet Label failed.')));

            const zpl = body.zpl;
            const copies = parseInt($copies.value) || 1;
            let msg = (notice ? `${notice} ` : '') + `✓ ${t('cartonsn.printPalletGeneratedMsg', 'Pallet label generated ({pallet}, {cartons} carton(s) / {units} unit(s)).')
                .replace('{pallet}', body.palletNumber).replace('{cartons}', body.quantityCartons).replace('{units}', body.quantityUnits)}`;
            let statusType = 'ok';

            if (printMode === 'usb') {
                const printerName = $usbSelect.value;
                if (printerName) {
                    try {
                        for (let i = 0; i < copies; i++) await sendToBridgeUsb(zpl, printerName);
                        msg += t('cartonsn.sentToUsbPrinter', ' Sent to USB printer "{name}" (Local Bridge).').replace('{name}', printerName);
                    } catch (e) {
                        statusType = 'err';
                        msg += t('cartonsn.sendToPrinterFailed', ' ✗ Failed to send to printer: {error}').replace('{error}', e.message);
                    }
                } else {
                    downloadZplFile(zpl, `pallet-${body.palletNumber}.zpl`);
                    msg += t('cartonsn.noUsbSelected', ' No USB printer selected — downloaded .zpl file instead.');
                }
            } else {
                const printerIp = $printerIp.value.trim();
                const printerPort = parseInt($printerPort.value) || 9100;
                if (printerIp) {
                    try {
                        for (let i = 0; i < copies; i++) await sendToBridge(zpl, printerIp, printerPort);
                        msg += t('cartonsn.sentToTcpPrinter', ' Sent to {ip}:{port} (Local Bridge).').replace('{ip}', printerIp).replace('{port}', printerPort);
                    } catch (e) {
                        statusType = 'err';
                        msg += t('cartonsn.sendToPrinterFailed', ' ✗ Failed to send to printer: {error}').replace('{error}', e.message);
                    }
                } else {
                    downloadZplFile(zpl, `pallet-${body.palletNumber}.zpl`);
                    msg += t('cartonsn.noIpSet', ' No printer IP set — downloaded .zpl file instead.');
                }
            }

            // Chốt pallet xong -> reset Pallet ID + badge để bắt đầu pallet mới ngay (carton đã
            // gán Pallet ID/Pallet Number vẫn giữ nguyên trong DB, chỉ xoá ô nhập trên UI). PO/
            // Inbound reference/Warehouse reference/Delivery address giữ nguyên, không reset.
            if (statusType === 'ok') {
                $palletId.value = '';
                localStorage.removeItem(LS_PALLET.id);
                setPalletBoxCount(0);
                updateCartonNumberLock(); // Pallet ID vừa xoá -> khoá lại Carton Number/Serial Number
            }
            showStatus($palletStatus, msg, statusType);
        } catch (e) {
            showStatus($palletStatus, `✗ ${e.message}`, 'err');
        } finally {
            $btnConfirmPrintPalletLabel.disabled = false;
        }
    }

    $btnConfirmPrintPalletLabel.addEventListener('click', () => {
        const palletId = $palletPrintConfirmOverlay.dataset.palletId || '';
        closePalletPrintConfirm();
        executePalletPrint(palletId);
    });

    $btnPrintPalletLabel.addEventListener('click', doPrintPalletLabel);

    // TEMP TEST — bản rút gọn của doPrintPalletLabel(), bỏ check bridgeOnline/isPrinterConfigured
    // và KHÔNG gửi bridge (luôn tải file .zpl) để test được "chốt pallet" (sinh Pallet Number,
    // lưu DB, reset Pallet ID/badge) khi máy in/Local Bridge đang lỗi. Xoá hẳn function này +
    // nút #btnTestPrintPalletLabel trong HTML sau khi test xong.
    const $btnTestPrintPalletLabel = document.getElementById('btnTestPrintPalletLabel');
    async function doTestPrintPalletLabel() {
        const palletId = $palletId.value.trim();
        if (!palletId) {
            showStatus($palletStatus, `✗ ${t('cartonsn.managePalletIdRequired', 'Enter a Pallet ID first.')}`, 'err');
            return;
        }
        if (!woResolvedOk || !resolvedColor) {
            showStatus($palletStatus, `✗ ${t('cartonsn.woLookupRequired', 'Look up a Work Order first.')}`, 'err');
            return;
        }
        const palletInfoError = validatePalletInfoFields();
        if (palletInfoError) {
            showStatus($palletStatus, `✗ ${palletInfoError}`, 'err');
            return;
        }

        $btnTestPrintPalletLabel.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/pallet/print`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    palletId,
                    poNumber: $poNumber.value.trim(),
                    inboundReference: $inboundReference.value.trim(),
                    warehouseReference: $warehouseReference.value.trim(),
                    deliveryAddress: $deliveryAddress.value.trim()
                })
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.printPalletFailed', 'Print Pallet Label failed.')));

            downloadZplFile(body.zpl, `pallet-${body.palletNumber}-TEST.zpl`);
            $palletId.value = '';
            localStorage.removeItem(LS_PALLET.id);
            $palletBoxCount.textContent = '0';
            updateCartonNumberLock(); // Pallet ID vừa xoá -> khoá lại Carton Number/Serial Number
            showStatus($palletStatus, `✓ [TEST] Pallet label generated (${body.palletNumber}, ${body.quantityCartons} carton(s) / ${body.quantityUnits} unit(s)) — no printer used, downloaded .zpl instead.`, 'ok');
        } catch (e) {
            showStatus($palletStatus, `✗ ${e.message}`, 'err');
        } finally {
            $btnTestPrintPalletLabel.disabled = false;
        }
    }
    $btnTestPrintPalletLabel.addEventListener('click', doTestPrintPalletLabel);

    // Carton Number không được trùng — mỗi carton là 1 định danh vật lý riêng, đã in rồi thì
    // không cho nhập lại. Check ngay khi bấm Enter (trước khi nhảy focus sang ô SN đầu tiên),
    // trùng thì báo lỗi + reset ô + focus lại để nhập cái khác (build-zpl vẫn re-check lại lần
    // nữa phòng trường hợp bỏ qua bước này — xem BuildCartonLabelZplAsync).
    async function verifyCartonNumber() {
        const value = $cartonNumber.value.trim();
        $cartonNumber.classList.remove('invalid');
        hideStatus($cartonNumberStatus);
        if (!value) return false;

        $cartonNumber.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/verify-carton-number?cartonNumber=${encodeURIComponent(value)}`);
            const body = await res.json();
            if (!res.ok || !body.ok) {
                $cartonNumber.classList.add('invalid');
                showStatus($cartonNumberStatus, `✗ ${window.SakuraI18n.translateApiError(body, t('cartonsn.cartonNumberAlreadyUsed', 'This Carton Number has already been used.'))}`, 'err');
                $cartonNumber.value = '';
                return false;
            }
            return true;
        } catch (e) {
            showStatus($cartonNumberStatus, `✗ ${t('cartonsn.cartonNumberCheckNetworkError', 'Could not verify Carton Number — check the network and try again.')}`, 'err');
            return false;
        } finally {
            $cartonNumber.disabled = false;
            $cartonNumber.focus();
        }
    }

    // Quét xong (máy quét thường không tự gửi Enter) → debounce 200ms rồi tự check + nhảy
    // xuống ô Serial đầu tiên, không cần bấm Enter thủ công nữa. Enter vẫn hoạt động để check
    // ngay lập tức cho ai gõ tay muốn xác nhận luôn.
    let cartonNumberDebounce;
    async function checkCartonNumberAndAdvance() {
        clearTimeout(cartonNumberDebounce);
        const ok = await verifyCartonNumber();
        if (ok) {
            unlockSerialGrid();
            document.querySelector('#serialGrid input')?.focus();
        } else {
            lockSerialGrid();
        }
    }

    $cartonNumber.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter') return;
        e.preventDefault();
        checkCartonNumberAndAdvance();
    });
    $cartonNumber.addEventListener('input', () => {
        $cartonNumber.classList.remove('invalid');
        hideStatus($cartonNumberStatus);
        // Carton Number đang đổi -> Serial Number của carton cũ không còn hợp lệ nữa, khóa +
        // xóa lại ngay (không chờ debounce network) để không lỡ in serial dưới carton sai.
        lockSerialGrid();
        clearTimeout(cartonNumberDebounce);
        cartonNumberDebounce = setTimeout(checkCartonNumberAndAdvance, 200);
    });

    // ── Serial numbers grid — quét barcode hoặc nhập tay (same pattern as /toast) ──
    // Số lượng serial/carton không còn ô nhập tay + nút Apply — tự tính từ Work Order lookup
    // (expectedQuantityThisCarton), mặc định MAX_SN_PER_CARTON khi chưa lookup.
    const $serialGrid   = document.getElementById('serialGrid');
    const $scannedCount = document.getElementById('scannedCount');
    const $scannedTotal = document.getElementById('scannedTotal');

    let serialList = [];

    function buildSerialGrid(qty) {
        qty = parseInt(qty) || MAX_SN_PER_CARTON;
        qty = Math.min(Math.max(qty, 1), MAX_SN_PER_CARTON);

        serialList = [];
        $serialGrid.innerHTML = '';
        $scannedTotal.textContent = qty;
        $scannedCount.textContent = '0';

        // 3 cột, đổ theo cột (SN1-4 cột 1, SN5-8 cột 2, SN9-10 cột 3) thay vì theo hàng.
        const rows = Math.ceil(qty / 3);
        $serialGrid.style.gridTemplateRows = `repeat(${rows}, auto)`;

        for (let i = 0; i < qty; i++) {
            const wrap = document.createElement('div');
            wrap.className = 'serial-input-wrap';
            wrap.innerHTML = `
                <span class="slot-idx">SN ${i + 1}</span>
                <input type="text" id="ser_${i}" placeholder="${t('cartonsn.serialSlotPlaceholder', 'Serial Number {n}').replace('{n}', i + 1)}" autocomplete="off" />
                <span class="serial-badge" id="badge_${i}"></span>`;
            $serialGrid.appendChild(wrap);
        }

        const inputs = $serialGrid.querySelectorAll('input');
        let timers = {};
        inputs.forEach((inp, idx) => {
            inp.addEventListener('input', () => {
                clearTimeout(timers[idx]);
                timers[idx] = setTimeout(() => handleSerialInput(inp, idx, inputs), 200);
            });
        });

        // Vừa build xong -> chưa có Carton Number nào được xác nhận cho carton này -> khóa
        // toàn bộ ô Serial Number lại (mở lại trong checkCartonNumberAndAdvance() khi Carton
        // Number hợp lệ — xem unlockSerialGrid()).
        lockSerialGrid();
    }

    // Serial Number chỉ mở khi Carton Number hiện tại đã được xác nhận hợp lệ (verifyCartonNumber
    // trả true) — tránh quét/nhập Serial Number khi chưa rõ carton nào. Khóa lại thì xóa sạch
    // luôn (giá trị Serial cũ không còn gắn với Carton Number hiện tại nữa).
    function lockSerialGrid() {
        serialList = [];
        $scannedCount.textContent = '0';
        $serialGrid.querySelectorAll('input').forEach(inp => {
            inp.disabled = true;
            inp.value = '';
            inp.className = '';
            inp.dataset.oldVal = '';
        });
        $serialGrid.querySelectorAll('.serial-badge').forEach(b => { b.className = 'serial-badge'; });
    }
    function unlockSerialGrid() {
        $serialGrid.querySelectorAll('input').forEach(inp => { inp.disabled = false; });
    }

    // 3 điều kiện check khi quét 1 SN vào carton (tránh in nhầm): (1) định dạng Serial Number,
    // (2) trùng với serial khác đã quét TRONG LẦN NÀY (client tự check bằng string/array —
    // serialList), (3) đã được quét/in ở carton khác chưa (phải tra DB, gọi server). (1) và (3)
    // cùng đi qua 1 API duy nhất (verify-serial) vì (3) cần DB, gọi 1 lần cho gọn.
    async function handleSerialInput(inp, idx, inputs) {
        const val = inp.value.trim();
        const badge = document.getElementById(`badge_${idx}`);

        if (!val) {
            if (inp.dataset.oldVal) serialList = serialList.filter(s => s !== inp.dataset.oldVal);
            inp.dataset.oldVal = '';
            inp.className = '';
            badge.className = 'serial-badge';
            $scannedCount.textContent = serialList.length;
            return;
        }

        // Check (2): trùng trong lần quét hiện tại — không cần gọi server.
        if (serialList.includes(val) && inp.dataset.oldVal !== val) {
            markInvalid(inp, badge, t('cartonsn.duplicateSerialShort', 'Duplicate'));
            showStatus($printStatus, `✗ ${t('cartonsn.duplicateSerial', 'Duplicate serial')}: ${val}`, 'err');
            inp.value = '';
            return;
        }

        // Check (1) + (3): định dạng + đã quét/in ở carton khác chưa.
        inp.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/verify-serial?serial=${encodeURIComponent(val)}`);
            const verify = await res.json();
            if (!res.ok || !verify.ok) {
                const shortLabel = verify.errorCode === 'cartonLabel.serialAlreadyUsed'
                    ? t('cartonsn.serialAlreadyUsedShort', 'Already used')
                    : t('cartonsn.invalidFormatShort', 'Invalid format');
                markInvalid(inp, badge, shortLabel);
                showStatus($printStatus, `✗ ${window.SakuraI18n.translateApiError(verify, t('cartonsn.serialCheckFailed', 'Serial check failed.'))}`, 'err');
                return;
            }
        } catch (e) {
            markInvalid(inp, badge, t('cartonsn.networkErrorShort', 'Network error'));
            showStatus($printStatus, `✗ ${t('cartonsn.serialCheckNetworkError', 'Could not verify this serial — check the network and try again.')}`, 'err');
            return;
        } finally {
            inp.disabled = false;
        }

        if (inp.dataset.oldVal) serialList = serialList.filter(s => s !== inp.dataset.oldVal);
        serialList.push(val);
        inp.dataset.oldVal = val;
        markValid(inp, badge);
        $scannedCount.textContent = serialList.length;

        if (idx < inputs.length - 1) {
            inputs[idx + 1].focus();
        } else if (serialList.length === inputs.length) {
            // Quét đủ số lượng đã đặt → tự động in luôn, không cần bấm nút nào cả.
            doPrint();
        }
    }

    function markValid(inp, badge) {
        inp.className = 'valid';
        badge.textContent = '✓';
        badge.className = 'serial-badge ok';
    }
    function markInvalid(inp, badge, msg) {
        inp.className = 'invalid';
        badge.textContent = msg;
        badge.className = 'serial-badge err';
        setTimeout(() => { inp.value = ''; inp.className = ''; badge.className = 'serial-badge'; }, 1400);
    }

    // ── Print Carton Label — build ZPL server-side, send to Local Bridge ──────
    const CARTON_REAL_PRINT_ENABLED = true;

    const $btnPrint  = document.getElementById('btnPrint');
    const $btnPreviewZpl = document.getElementById('btnPreviewZpl');
    const $printStatus = document.getElementById('printStatus');

    function isPrinterConfigured() {
        return printMode === 'usb' ? !!$usbSelect.value : !!$printerIp.value.trim();
    }
    function printerNotReadyMessage() {
        return !bridgeOnline
            ? t('cartonsn.printerServiceOffline', 'Print Service is offline — cannot print.')
            : t('cartonsn.printerNotConnected', 'No printer connected — select a printer in Printer Configuration first.');
    }

    // Browser → local bridge (localhost:8021) → printer, same flow as SN Label / Toast pages.
    async function sendToBridge(zpl, printerIp, printerPort) {
        const res = await fetch(`${NODE_SERVICE}/print`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ zpl, printerIp, printerPort })
        });
        if (!res.ok) throw new Error(t('cartonsn.bridgeSendFailed', 'Failed to send print job to Local Bridge.'));
    }

    async function sendToBridgeUsb(zpl, printerName) {
        const res = await fetch(`${NODE_SERVICE}/print-usb`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ zpl, printerName })
        });
        const data = await res.json().catch(() => null);
        if (!res.ok || !data || data.success === false) {
            throw new Error((data && data.error) || t('cartonsn.bridgeSendFailedUsb', 'Failed to send print job to Local Bridge (USB).'));
        }
    }

    function downloadZplFile(zpl, filename) {
        const blob = new Blob([zpl], { type: 'text/plain' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
    }

    // Mảng gửi lên server phải đúng VỊ TRÍ ô SN1..SN10 trên form (khớp {sn1}..{sn10} trong
    // template) — không dùng serialList (chỉ để đếm/check trùng), vì serialList xếp theo thứ
    // tự gõ/sửa xong ô nào trước, không phải theo đúng ô. Đọc trực tiếp .value của từng input
    // theo đúng thứ tự DOM, ô nào đang trống thì giữ nguyên chuỗi rỗng ở đúng vị trí đó.
    function getOrderedSerials() {
        return Array.from($serialGrid.querySelectorAll('input')).map(inp => inp.value.trim());
    }

    // Đọc + validate Work Order/Carton Number trước khi gọi API build ZPL — dùng chung cho cả
    // Print lẫn Preview ZPL (Preview không cần bridge/máy in, chỉ cần build+xem ZPL). Color giờ
    // lấy tự động từ Work Order lookup (resolvedColor), Condition tạm cố định "New".
    function readCartonFormOrNull() {
        const cartonNumber = $cartonNumber.value.trim();

        if (!woResolvedOk || !resolvedColor) {
            showStatus($printStatus, `✗ ${t('cartonsn.woLookupRequired', 'Look up a Work Order first.')}`, 'err');
            $workOrder.focus();
            return null;
        }
        if (!cartonNumber) {
            showStatus($printStatus, `✗ ${t('cartonsn.cartonNumberRequired', 'Enter a Carton Number first.')}`, 'err');
            $cartonNumber.focus();
            return null;
        }
        if (serialList.length === 0) {
            showStatus($printStatus, `✗ ${t('cartonsn.noSerials', 'Scan at least 1 serial number first.')}`, 'err');
            return null;
        }
        return { workOrder: $workOrder.value.trim(), cartonNumber, color: resolvedColor, condition: CARTON_FIXED_CONDITION, palletId: $palletId.value.trim() };
    }

    // Xem/tải ZPL sau khi đã thay biến — gọi thẳng server build ZPL, KHÔNG cần Local Bridge
    // hay máy in kết nối (vd đang test ở nhà, không có mạng tới máy in) — chỉ để kiểm tra
    // nội dung ZPL cuối cùng trước khi in thật.
    async function previewZpl() {
        const form = readCartonFormOrNull();
        if (!form) return;

        $btnPreviewZpl.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/print`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ...form, serialNumbers: getOrderedSerials() })
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.printFailed', 'Print failed.')));

            downloadZplFile(body.zpl, `carton-${form.cartonNumber}-preview.zpl`);

            // Theo yêu cầu hiện tại (đang giai đoạn test, chưa in tem thật) — Preview ZPL cũng
            // tính là đã "in xong": lưu DB + reset Carton Number/Serial Number, y hệt luồng in
            // thật (doPrint). Nút Print thật đang ẩn nên đây là cách duy nhất để test hết luồng.
            const result = await finishSuccessfulPrint(form);
            const reportOk = !!result;
            let reportWarning = reportOk ? '' : ` ⚠ ${t('cartonsn.reportResultFailed', 'Could not save the scan record to the server.')}`;
            if (reportOk && result.palletAttachWarning) reportWarning += ` ⚠ ${result.palletAttachWarning}`;
            showStatus($printStatus, `✓ ${t('cartonsn.zplPreviewReady', 'ZPL preview downloaded — no printer needed to check it.')}${reportWarning}`, reportOk ? 'ok' : 'err');
        } catch (e) {
            showStatus($printStatus, `✗ ${e.message}`, 'err');
        } finally {
            $btnPreviewZpl.disabled = false;
        }
    }

    $btnPreviewZpl.addEventListener('click', previewZpl);

    // Lưu các serial không rỗng vào DB (SM_Sakura_CartonLabel_Data) — CHỈ gọi sau khi ZPL coi
    // như đã "in xong" (bridge thành công, hoặc Preview theo yêu cầu test hiện tại). Gửi kèm
    // Pallet ID đang nhập (nếu có) để server gom thẳng carton này vào pallet ngay lúc lưu — xem
    // RecordCartonScanAsync. Trả về body đầy đủ (thay vì chỉ true/false) để lấy count mới nhất
    // + cảnh báo khác màu (nếu có).
    async function reportCartonPrintResult(form, orderedSerials) {
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/report-print-result`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ...form, serialNumbers: orderedSerials, palletId: $palletId.value.trim() })
            });
            const body = await res.json().catch(() => null);
            return (res.ok && body && body.ok) ? body : null;
        } catch (e) {
            return null;
        }
    }

    // Sau khi 1 tem coi như đã "in xong" -> lưu DB (kèm gom vào Pallet nếu có Pallet ID), cập
    // nhật ngay badge "Boxes in Pallet" từ count server trả về, rồi LOOKUP LẠI WO (không tin số
    // cộng dồn cục bộ — có thể trạm khác cũng đang in cùng WO này) để lấy đúng Qty Print/Remain
    // thật từ server. lookupWorkOrder() tự lo xóa/khóa Carton Number + Serial Number rồi mở lại +
    // build đúng số ô cho carton kế tiếp nếu WO còn hàng (xem resetWoState()) — nếu WO đã hết thì
    // giữ nguyên khóa + hiện thông báo, không cần code gì thêm ở đây. Dùng chung cho cả doPrint
    // (in thật) lẫn previewZpl (đang test, xem mục đích ở previewZpl()).
    async function finishSuccessfulPrint(form) {
        const result = await reportCartonPrintResult(form, getOrderedSerials());
        if (result && result.pallet) setPalletBoxCount(result.pallet.boxCount);
        await lookupWorkOrder();
        if (result && result.pallet && form.palletId) await maybeAutoPrintPallet(form.palletId, result.pallet.boxCount);
        return result;
    }

    // "Auto Print At" đã set VÀ pallet vừa đạt/vượt số đó -> tự in tem Pallet ngay, không cần bấm
    // Print Pallet Label/xác nhận modal (xem executePalletPrint()). Nếu WO vừa hết carton để quét
    // tiếp (lookupWorkOrder() ở trên fail -> woResolvedOk = false) NHƯNG pallet chưa đạt đủ số đã
    // set (VD set 64, WO chỉ còn dư 56 thùng cho pallet cuối) -> không thể chờ đủ 64 được nữa vì
    // hết carton rồi, nên in luôn với đúng số thùng thực tế đang có + báo rõ thiếu bao nhiêu.
    async function maybeAutoPrintPallet(palletId, boxCount) {
        const target = getPalletTargetBoxCount();
        if (!target || boxCount <= 0) return;

        if (boxCount >= target) {
            await autoExecutePalletPrint(palletId, '');
            return;
        }

        if (!woResolvedOk) {
            const notice = `⚠ ${t('cartonsn.palletTargetShortfall', 'Work Order is out of cartons — this pallet only reached {count}/{target} boxes. Printing with the remaining {count} box(es) instead.')
                .replace(/{count}/g, boxCount).replace('{target}', target)}`;
            await autoExecutePalletPrint(palletId, notice);
        }
    }

    // Check tối thiểu (bỏ qua check WO/Color — lúc gọi từ nhánh "WO đã hết carton" ở trên,
    // woResolvedOk/resolvedColor CHẮC CHẮN đang null, đó là điều kiện gọi, không phải lỗi) trước
    // khi tự in — vẫn cần Info Template hợp lệ + bridge/máy in sẵn sàng như in tay.
    async function autoExecutePalletPrint(palletId, notice) {
        const palletInfoError = validatePalletInfoFields();
        if (palletInfoError) {
            showStatus($palletStatus, `✗ ${palletInfoError}`, 'err');
            return;
        }
        if (!bridgeOnline || !isPrinterConfigured()) {
            showStatus($palletStatus, `✗ ${printerNotReadyMessage()}`, 'err');
            return;
        }
        await executePalletPrint(palletId, notice);
    }

    let printing = false;

    async function doPrint() {
        if (printing || !CARTON_REAL_PRINT_ENABLED) return;

        const form = readCartonFormOrNull();
        if (!form) return;
        const { cartonNumber, color, condition } = form;

        if (!bridgeOnline || !isPrinterConfigured()) {
            showStatus($printStatus, `✗ ${printerNotReadyMessage()}`, 'err');
            return;
        }

        printing = true;
        $btnPrint.disabled = true;
        try {
            const res = await fetch(`${BASE}/api/sakura/cartonsn/print`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cartonNumber, color, condition, serialNumbers: getOrderedSerials(), workOrder: $workOrder.value.trim(), palletId: $palletId.value.trim() })
            });
            const body = await res.json();
            if (!res.ok || !body.ok) throw new Error(window.SakuraI18n.translateApiError(body, t('cartonsn.printFailed', 'Print failed.')));

            const zpl = body.zpl;
            const copies = parseInt($copies.value) || 1;
            let msg = `✓ ${t('cartonsn.generatedLabelMsg', 'Carton label generated ({n} serial(s)).').replace('{n}', serialList.length)}`;
            let statusType = 'ok';
            let sentOk = false;

            if (printMode === 'usb') {
                const printerName = $usbSelect.value;
                if (printerName) {
                    try {
                        for (let i = 0; i < copies; i++) await sendToBridgeUsb(zpl, printerName);
                        msg += t('cartonsn.sentToUsbPrinter', ' Sent to USB printer "{name}" (Local Bridge).').replace('{name}', printerName);
                        sentOk = true;
                    } catch (e) {
                        statusType = 'err';
                        msg += t('cartonsn.sendToPrinterFailed', ' ✗ Failed to send to printer: {error}').replace('{error}', e.message);
                    }
                } else {
                    downloadZplFile(zpl, `carton-${cartonNumber}.zpl`);
                    msg += t('cartonsn.noUsbSelected', ' No USB printer selected — downloaded .zpl file instead.');
                }
            } else {
                const printerIp = $printerIp.value.trim();
                const printerPort = parseInt($printerPort.value) || 9100;
                if (printerIp) {
                    try {
                        for (let i = 0; i < copies; i++) await sendToBridge(zpl, printerIp, printerPort);
                        msg += t('cartonsn.sentToTcpPrinter', ' Sent to {ip}:{port} (Local Bridge).').replace('{ip}', printerIp).replace('{port}', printerPort);
                        sentOk = true;
                    } catch (e) {
                        statusType = 'err';
                        msg += t('cartonsn.sendToPrinterFailed', ' ✗ Failed to send to printer: {error}').replace('{error}', e.message);
                    }
                } else {
                    downloadZplFile(zpl, `carton-${cartonNumber}.zpl`);
                    msg += t('cartonsn.noIpSet', ' No printer IP set — downloaded .zpl file instead.');
                }
            }

            // Chỉ ghi DB khi ZPL thật sự đã gửi tới máy in thành công — tải file .zpl (nhánh
            // "không có IP/USB") không tính là đã in, không được trừ vào số lượng Work Order.
            if (sentOk) {
                const result = await finishSuccessfulPrint(form);
                if (!result) msg += ` ⚠ ${t('cartonsn.reportResultFailed', 'Could not save the scan record to the server.')}`;
                else if (result.palletAttachWarning) msg += ` ⚠ ${result.palletAttachWarning}`;
            }
            showStatus($printStatus, msg, statusType);
        } catch (e) {
            showStatus($printStatus, `✗ ${e.message}`, 'err');
        } finally {
            printing = false;
            $btnPrint.disabled = false;
        }
    }

    $btnPrint.addEventListener('click', doPrint);

    // ── Printer Configuration — collapsed by default, same pattern as SN Label ────────────
    const $printerConfigBody = document.getElementById('printerConfigBody');
    const $btnTogglePrinterConfig = document.getElementById('btnTogglePrinterConfig');
    let printerConfigOpen = false;
    function setPrinterConfigOpen(open) {
        printerConfigOpen = open;
        $printerConfigBody.style.display = open ? '' : 'none';
        $btnTogglePrinterConfig.classList.toggle('open', open);
        $btnTogglePrinterConfig.setAttribute('aria-expanded', String(open));
    }
    $btnTogglePrinterConfig.addEventListener('click', () => setPrinterConfigOpen(!printerConfigOpen));

    // ── Print Label (Work Order) — same collapse pattern, open by default so the operator can
    // type/scan a Work Order right away; collapse manually once resolved to save space. ──
    const $printLabelBody = document.getElementById('printLabelBody');
    const $btnTogglePrintLabel = document.getElementById('btnTogglePrintLabel');
    let printLabelOpen = true;
    function setPrintLabelOpen(open) {
        printLabelOpen = open;
        $printLabelBody.style.display = open ? '' : 'none';
        $btnTogglePrintLabel.classList.toggle('open', open);
        $btnTogglePrintLabel.setAttribute('aria-expanded', String(open));
    }
    $btnTogglePrintLabel.addEventListener('click', () => setPrintLabelOpen(!printLabelOpen));

    // ── Printer config — same pattern as SN Label / Toast pages ───────────────
    const $printerIp   = document.getElementById('printerIp');
    const $printerPort = document.getElementById('printerPort');
    const $copies      = document.getElementById('copies');
    const $btnSavePrinter = document.getElementById('btnSavePrinter');
    const $printerSavedHint = document.getElementById('printerSavedHint');
    const $printerHint = document.getElementById('printerHint');

    const $nodeDot = document.getElementById('nodeDot');
    const $nodeTxt = document.getElementById('nodeTxt');
    const $lblTcp   = document.getElementById('lblTcp');
    const $lblUsb   = document.getElementById('lblUsb');
    const $tcpBlock = document.getElementById('tcpBlock');
    const $usbBlock = document.getElementById('usbBlock');
    const $usbSelect = document.getElementById('usbSelect');
    const $usbStatus = document.getElementById('usbStatus');
    const $btnRefreshUsb = document.getElementById('btnRefreshUsb');

    let printMode = 'tcp';
    let bridgeOnline = false;

    const LS = {
        ip: 'sakura_cartonsn_ip',
        port: 'sakura_cartonsn_port',
        copies: 'sakura_cartonsn_copies',
        mode: 'sakura_cartonsn_print_mode',
        usbName: 'sakura_cartonsn_usb_name',
        saved: 'sakura_cartonsn_printer_saved'
    };

    function loadPrinterConfig() {
        const v = k => localStorage.getItem(k);
        if (v(LS.ip)) $printerIp.value = v(LS.ip);
        if (v(LS.port)) $printerPort.value = v(LS.port);
        if (v(LS.copies)) $copies.value = v(LS.copies);
        setPrintMode(v(LS.mode) === 'usb' ? 'usb' : 'tcp');

        // Đã từng Save trước khi F5 -> hiện lại đèn "✓ Saved" ngay (không chờ bấm lại Save).
        if (v(LS.saved) === '1') {
            $printerSavedHint.classList.add('show');
        }
    }

    $btnSavePrinter.addEventListener('click', () => {
        localStorage.setItem(LS.ip, $printerIp.value.trim());
        localStorage.setItem(LS.port, $printerPort.value.trim());
        localStorage.setItem(LS.copies, $copies.value.trim());
        localStorage.setItem(LS.usbName, $usbSelect.value || '');
        localStorage.setItem(LS.saved, '1');

        // Giữ nguyên "✓ Saved" cho tới khi refresh trang — không tự ẩn.
        $printerSavedHint.classList.add('show');
    });

    function setPrintMode(mode) {
        printMode = mode;
        $lblTcp.classList.toggle('active', mode === 'tcp');
        $lblUsb.classList.toggle('active', mode === 'usb');
        $tcpBlock.style.display = mode === 'tcp' ? '' : 'none';
        $usbBlock.style.display = mode === 'usb' ? '' : 'none';
        localStorage.setItem(LS.mode, mode);
        if (mode === 'usb' && $usbSelect.options.length <= 1) loadUsbPrinters();
    }

    $lblTcp.addEventListener('click', () => setPrintMode('tcp'));
    $lblUsb.addEventListener('click', () => setPrintMode('usb'));

    async function loadUsbPrinters() {
        $usbSelect.innerHTML = `<option value="">${t('cartonsn.usbScanning', '⏳ Scanning…')}</option>`;
        $usbSelect.disabled = true;
        $usbStatus.textContent = '';
        $usbStatus.className = 'usb-status';

        try {
            const r = await fetch(`${NODE_SERVICE}/usb-printers`, { signal: AbortSignal.timeout(6000) });
            const data = await r.json();

            if (!data.printers || data.printers.length === 0) {
                $usbSelect.innerHTML = `<option value="">${t('cartonsn.usbNoPrinterFound', '— No printer found —')}</option>`;
                $usbStatus.textContent = t('cartonsn.usbNoPrinterDetected', 'No USB printer detected.');
                $usbStatus.className = 'usb-status bad';
                return;
            }

            $usbSelect.innerHTML = `<option value="">${t('cartonsn.usbSelectPrinter', '— Select printer —')}</option>` +
                data.printers.map(p => `<option value="${escHtml(p)}">${escHtml(p)}</option>`).join('');
            $usbSelect.disabled = false;
            $usbStatus.textContent = t('cartonsn.usbFoundCount', '✓ Found {n} printer(s).').replace('{n}', data.printers.length);
            $usbStatus.className = 'usb-status ok';

            // Tự chọn lại máy in USB đã Save trước đó, nếu vẫn có trong danh sách quét được.
            const savedUsbName = localStorage.getItem(LS.usbName);
            if (savedUsbName && data.printers.includes(savedUsbName)) {
                $usbSelect.value = savedUsbName;
            }
        } catch (err) {
            $usbSelect.innerHTML = `<option value="">${t('cartonsn.usbLoadError', '— Load error —')}</option>`;
            $usbStatus.textContent = t('cartonsn.usbCannotConnect', 'Cannot connect to localhost:8021.');
            $usbStatus.className = 'usb-status bad';
        }
    }

    $btnRefreshUsb.addEventListener('click', () => {
        $printerSavedHint.classList.remove('show');
        loadUsbPrinters();
    });

    async function checkNode() {
        try {
            const r = await fetch(`${NODE_SERVICE}/health`, { signal: AbortSignal.timeout(2500) });
            if (r.ok) {
                $nodeDot.className = 'node-dot alive';
                $nodeTxt.textContent = t('cartonsn.bridgeOnline', 'Service — Online');
                bridgeOnline = true;
                return;
            }
        } catch { /* offline */ }
        $nodeDot.className = 'node-dot dead';
        $nodeTxt.textContent = t('cartonsn.bridgeOffline', 'Service — Offline');
        bridgeOnline = false;
    }
    checkNode();
    setInterval(checkNode, 8000);

    // Re-render locally-cached dynamic text (Service status, SN placeholders)
    // when EN/ZH is switched, without hitting any API or rebuilding the grid.
    document.addEventListener('sakura:lang-changed', () => {
        $nodeTxt.textContent = bridgeOnline
            ? t('cartonsn.bridgeOnline', 'Service — Online')
            : t('cartonsn.bridgeOffline', 'Service — Offline');
        $serialGrid.querySelectorAll('input').forEach((inp, idx) => {
            inp.placeholder = t('cartonsn.serialSlotPlaceholder', 'Serial Number {n}').replace('{n}', idx + 1);
        });
    });

    // ── init ──────────────────────────────────────────────────────────────────
    loadWoFields();
    loadPrinterConfig();
    loadPalletFields();
    initPalletTemplates();
    // Chưa lookup WO nào -> Carton Number/Serial Number/Print Pallet khóa sẵn (xem resetWoState()).
    resetWoState();

    // Luồng tuần tự bắt buộc lúc vào trang: Printer Configuration -> Work Order -> Pallet ID ->
    // Carton Number. Bước nào đã "Save" trước đó rồi thì tự nhảy qua bước kế tiếp — Pallet ID/
    // Carton Number được cascade tiếp bên trong lookupWorkOrder() sau khi lookup xong.
    const printerAlreadySaved = localStorage.getItem(LS.saved) === '1';
    setPrinterConfigOpen(!printerAlreadySaved);
    if (!printerAlreadySaved) {
        (printMode === 'usb' ? $usbSelect : $printerIp).focus();
    } else if (localStorage.getItem(LS_WO)) {
        $btnSaveWo.classList.add('is-saved');
        lookupWorkOrder();
    } else {
        $workOrder.focus();
    }
})();
</script>
}
