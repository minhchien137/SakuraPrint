<div class="sk-lang-switch" id="skLangSwitch">
    <button type="button" class="sk-lang-flag" data-lang="en" title="English" aria-label="English">
        <img src="@Url.Content("~/images/en.png")" alt="EN" />
    </button>
    <button type="button" class="sk-lang-flag" data-lang="zh" title="中文" aria-label="中文">
        <img src="@Url.Content("~/images/cn.png")" alt="ZH" />
    </button>
</div>
